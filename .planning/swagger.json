{
  "openapi": "3.0.4",
  "info": {
    "title": "Staccato API",
    "description": "Backend API for the Staccato instrument learning notebook application.",
    "version": "v1"
  },
  "paths": {
    "/auth/register": {
      "post": {
        "tags": ["Auth"],
        "requestBody": {
          "content": {
            "application/json": { "schema": { "$ref": "#/components/schemas/RegisterRequest" } }
          }
        },
        "responses": { "200": { "description": "OK" } }
      }
    },
    "/auth/login": {
      "post": {
        "tags": ["Auth"],
        "requestBody": {
          "content": {
            "application/json": { "schema": { "$ref": "#/components/schemas/LoginRequest" } }
          }
        },
        "responses": { "200": { "description": "OK" } }
      }
    },
    "/auth/refresh": {
      "post": {
        "tags": ["Auth"],
        "responses": { "200": { "description": "OK" } }
      }
    },
    "/auth/google": {
      "post": {
        "tags": ["Auth"],
        "requestBody": {
          "content": {
            "application/json": { "schema": { "$ref": "#/components/schemas/GoogleAuthRequest" } }
          }
        },
        "responses": { "200": { "description": "OK" } }
      }
    },
    "/auth/logout": {
      "post": {
        "tags": ["Auth"],
        "responses": { "200": { "description": "OK" } }
      }
    },
    "/chords": {
      "get": {
        "tags": ["Chords"],
        "parameters": [
          { "name": "instrument", "in": "query", "required": true, "schema": { "$ref": "#/components/schemas/InstrumentKey" } },
          { "name": "root", "in": "query", "schema": { "type": "string" } },
          { "name": "quality", "in": "query", "schema": { "type": "string" } },
          { "name": "extension", "in": "query", "schema": { "type": "string" } },
          { "name": "alternation", "in": "query", "schema": { "type": "string" } }
        ],
        "responses": { "200": { "description": "OK" } }
      }
    },
    "/chords/{id}": {
      "get": {
        "tags": ["Chords"],
        "parameters": [
          { "name": "id", "in": "path", "required": true, "schema": { "type": "string", "format": "uuid" } }
        ],
        "responses": { "200": { "description": "OK" } }
      }
    },
    "/exports": {
      "post": {
        "tags": ["Exports"],
        "requestBody": {
          "content": {
            "application/json": { "schema": { "$ref": "#/components/schemas/CreatePdfExportRequest" } }
          }
        },
        "responses": { "200": { "description": "OK" } }
      },
      "get": {
        "tags": ["Exports"],
        "responses": { "200": { "description": "OK" } }
      }
    },
    "/exports/{id}": {
      "get": {
        "tags": ["Exports"],
        "parameters": [
          { "name": "id", "in": "path", "required": true, "schema": { "type": "string", "format": "uuid" } }
        ],
        "responses": { "200": { "description": "OK" } }
      },
      "delete": {
        "tags": ["Exports"],
        "parameters": [
          { "name": "id", "in": "path", "required": true, "schema": { "type": "string", "format": "uuid" } }
        ],
        "responses": { "200": { "description": "OK" } }
      }
    },
    "/exports/{id}/download": {
      "get": {
        "tags": ["Exports"],
        "parameters": [
          { "name": "id", "in": "path", "required": true, "schema": { "type": "string", "format": "uuid" } }
        ],
        "responses": { "200": { "description": "OK" } }
      }
    },
    "/instruments": {
      "get": {
        "tags": ["Instruments"],
        "responses": { "200": { "description": "OK" } }
      }
    },
    "/lessons/{id}/pages": {
      "get": {
        "tags": ["LessonPages"],
