          { "name": "id", "in": "path", "required": true, "schema": { "type": "string", "format": "uuid" } }
        ],
        "responses": { "200": { "description": "OK" } }
      },
      "post": {
        "tags": ["LessonPages"],
        "parameters": [
          { "name": "id", "in": "path", "required": true, "schema": { "type": "string", "format": "uuid" } }
        ],
        "responses": { "200": { "description": "OK" } }
      }
    },
    "/lessons/{lessonId}/pages/{pageId}": {
      "delete": {
        "tags": ["LessonPages"],
        "parameters": [
          { "name": "lessonId", "in": "path", "required": true, "schema": { "type": "string", "format": "uuid" } },
          { "name": "pageId", "in": "path", "required": true, "schema": { "type": "string", "format": "uuid" } }
        ],
        "responses": { "200": { "description": "OK" } }
      }
    },
    "/notebooks/{id}/lessons": {
      "get": {
        "tags": ["Lessons"],
